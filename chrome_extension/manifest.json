{
  "manifest_version": 3,
  "name": "QAmatomer Dev Launcher",
  "description": "Launch or side-panel QAmatomer_dev.html from a configurable URL for extension-based workflows.",
  "version": "0.2.0",
  "action": {
    "default_title": "Open QAmatomer Dev",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
