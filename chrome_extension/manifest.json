{
  "manifest_version": 3,
  "name": "QAmatomer Dev Launcher",
  "description": "Launch QAmatomer_dev.html from a configurable URL for extension-based workflows.",
  "version": "0.1.0",
  "action": {
    "default_title": "Open QAmatomer Dev",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
